@page "/"
@inject ModelViewerService Viewer
@inject InteractionProcessor Processor
@inject IUdpReceiverService UdpService
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="toolbar" style="padding: 10px; background: #1e1e1e; color: white; display: flex; gap: 15px; align-items: center; flex-wrap: wrap;">
    <button @onclick="HandleFilePicker" style="padding: 8px 16px; cursor: pointer; border-radius: 4px; border: none; background: #0078d7; color: white; font-weight: bold;">Carregar Modelo 3D</button>
    <button @onclick="() => _showTips = true" style="padding: 8px 16px; cursor: pointer; border-radius: 4px; border: none; background: #444; color: white; font-weight: bold;">Dicas</button>
    
    <div class="status-panel" style="display: flex; gap: 15px; align-items: center;">
        <span>Mãos: <strong>@_handCount</strong></span>
        <span>Modo: <strong>@_currentMode</strong></span>
        <span>Pan X: @Processor.PanX.ToString("F2") | Y: @Processor.PanY.ToString("F2")</span>
    </div>
    
    <div style="display: flex; align-items: center; gap: 8px; margin-left: auto; background: #333; padding: 5px 15px; border-radius: 20px;">
        <span>Zoom: <strong>@Processor.Scale.ToString("F1")x</strong></span>
    </div>
</div>

<model-viewer id="main-viewer" src="https://modelviewer.dev/shared-assets/models/Astronaut.glb" camera-controls interaction-prompt="none"></model-viewer>

@if (_showTips)
{
    <div class="modal-overlay" style="position: absolute; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); color:white; display:flex; flex-direction:column; justify-content:center; align-items:center; z-index:100;">
        <h3>Dicas de Interação</h3>
        <ul style="list-style:none; padding:0; line-height:2em;">
            <li><strong>1 Mão Aberta:</strong> Rodar o Modelo</li>
            <li><strong>1 Mão Fechada:</strong> Mover o Modelo</li>
            <li><strong>2 Mãos Abertas:</strong> Zoom (Aproximar/Afastar)</li>
        </ul>
        <button @onclick="() => _showTips = false" style="margin-top:20px; padding: 10px 20px; background: #0078d7; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold;">Fechar</button>
    </div>
}

@code {
    private bool _showTips = false;
    private string _currentMode = "Inativo";
    private int _handCount = 0;

    protected override void OnInitialized()
    {
        UdpService.OnDataReceived += HandleData;
        UdpService.StartListening();
    }

    private void HandleData(TrackingData data)
    {
        _handCount = data.Hands?.Count ?? 0;
        var (updated, mode) = Processor.Process(data.Hands ?? new());
        _currentMode = mode;

        if (updated)
        {
            InvokeAsync(async () => {
                if (mode == "Zoom") await Viewer.UpdateScaleAsync(Processor.Scale);
                else if (mode == "Rotação") await Viewer.UpdateRotationAsync(Processor.Theta, Processor.Phi);
                else if (mode == "Pan") await Viewer.UpdatePanAsync(Processor.PanX, Processor.PanY);
                StateHasChanged();
            });
        }
        else
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleFilePicker()
    {
        var fileUrl = await JSRuntime.InvokeAsync<string>("eval", @"
            new Promise((resolve) => {
                const input = document.createElement('input');
                input.type = 'file';
                input.accept = '.glb,.gltf';
                input.onchange = e => {
                    const file = e.target.files[0];
                    if(file) {
                        resolve(URL.createObjectURL(file));
                    } else {
                        resolve('');
                    }
                };
                input.click();
            })
        ");

        if (!string.IsNullOrEmpty(fileUrl))
        {
            await Viewer.LoadModelAsync(fileUrl);
        }
    }

    public void Dispose()
    {
        UdpService.OnDataReceived -= HandleData;
        UdpService.StopListening();
    }
}